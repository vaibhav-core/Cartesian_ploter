<sdf version='1.11'>
  <model name='cartesian_plotter'>
    <joint name='world_to_base' type='fixed'>
      <pose relative_to='__model__'>0 0 0 0 0 0</pose>
      <parent>world</parent>
      <child>base_link</child>
    </joint>
    <link name='base_link'>
      <pose relative_to='world_to_base'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>2</mass>
        <inertia>
          <ixx>1.1000000000000001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>1.1000000000000001</iyy>
          <iyz>0</iyz>
          <izz>1.1000000000000001</izz>
        </inertia>
      </inertial>
      <visual name='base_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>0.050000000000000003 0.050000000000000003 0.050000000000000003</scale>
            <uri>file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/base_link_NEW.stl</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0 0 0 1</diffuse>
          <ambient>0 0 0 1</ambient>
        </material>
      </visual>
      <visual name='base_link_fixed_joint_lump__X_Rail_visual_1'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>0.050000000000000003 0.050000000000000003 0.050000000000000003</scale>
            <uri>file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/x_rail_NEW.stl</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0 0 1 1</diffuse>
          <ambient>0 0 1 1</ambient>
        </material>
      </visual>
    </link>
    <joint name='x_to_y' type='prismatic'>
      <pose relative_to='base_link'>0 0 0 0 0 0</pose>
      <parent>base_link</parent>
      <child>Y_rail</child>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>0</lower>
          <upper>0.5</upper>
          <effort>100</effort>
          <velocity>1</velocity>
        </limit>
        <dynamics>
          <damping>1</damping>
          <friction>0</friction>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='Y_rail'>
      <pose relative_to='x_to_y'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>1</mass>
        <inertia>
          <ixx>0.10000000000000001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.10000000000000001</iyy>
          <iyz>0</iyz>
          <izz>0.10000000000000001</izz>
        </inertia>
      </inertial>
      <visual name='Y_rail_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>0.050000000000000003 0.050000000000000003 0.050000000000000003</scale>
            <uri>file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/y_slider_NEW.stl</uri>
          </mesh>
        </geometry>
        <material>
          <diffuse>0 0 1 1</diffuse>
          <ambient>0 0 1 1</ambient>
        </material>
      </visual>
    </link>
    <plugin name='gz::sim::systems::JointPositionController' filename='gz-sim-joint-position-controller-system'>
      <joint_name>x_to_y</joint_name>
      <p_gain>10</p_gain>
      <i_gain>0.01</i_gain>
      <d_gain>1.0</d_gain>
      <i_max>1</i_max>
      <i_min>-1</i_min>
      <cmd_max>100</cmd_max>
      <cmd_min>-100</cmd_min>
    </plugin>
    <frame name='base_to_x' attached_to='base_link'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='X_Rail' attached_to='base_to_x'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
  </model>
</sdf>
