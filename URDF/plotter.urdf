<?xml version="1.0"?>

<robot name="cartesian_plotter">

  <link name="X_Rail">
    <visual>
     
     
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
     
     
      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>

        <mesh filename="file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/x_rail.stl"
              scale=".01 .01 .01"/>

      </geometry>

    </visual>

    <collision>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <box size="1 1 1"/>
      </geometry>

    </collision>

    <inertial>

      <mass value="1.0"/>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>

    </inertial>

  </link>

  <link name="Y_rail">
    <visual>
        
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    
   
      <origin xyz="0 0 0" rpy="0 0 0" />

      <geometry>
      <mesh filename="file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/X_carriage_and_Y_rail.stl"
              scale=".01 .01 .01"/> 
      </geometry>
    </visual>

    
      <collision>

      <origin xyz="0 0 0" rpy="0 0 0"/>

      <geometry>
        <box size="1 1 1"/>
      </geometry>

      </collision>

      <inertial>

        <mass value="1.0"/>

        <origin xyz="0 0 0" rpy="0 0 0"/>

        <inertia ixx="0.1" ixy="0.0" ixz="0.0"
            iyy="0.1" iyz="0.0"
            izz="0.1"/>

       </inertial>
  
  
  </link>

  <joint name="x_to_y" type="fixed">

    <parent link="X_Rail"/>
    <child link="Y_rail"/>

    <origin xyz="0 0 .10" rpy="0 0 0"/>

  </joint>

</robot>