cat > /home/vaibhav/programming_projects/Robotics/Cartesian_ploter/URDF/plotter.urdf << 'EOF'
<?xml version="1.0"?>
<robot name="cartesian_plotter">
    <link name="X_Rail">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh>
                    <uri>file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/x_rail.stl</uri>
                    <scale>0.01 0.01 0.01</scale>
                </mesh>
            </geometry>
            <material>
                <ambient>0.5 0.5 0.55 1</ambient>
                <diffuse>0.6 0.6 0.65 1</diffuse>
                <specular>0.1 0.1 0.1 1</specular>
                <emissive>0 0 0 1</emissive>
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh>
                    <uri>file:///home/vaibhav/programming_projects/Robotics/Cartesian_ploter/Meshes/x_rail.stl</uri>
                    <scale>0.01 0.01 0.01</scale>
                </mesh>
            </geometry>
        </collision>

        <inertial>
            <mass value="1.5"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                     iyy="0.01" iyz="0.0" izz="0.01"/>
        </inertial>
    </link>
